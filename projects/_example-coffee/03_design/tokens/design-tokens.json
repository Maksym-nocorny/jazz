{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "_comment": "ВОВК Coffee — Craft Editorial direction. Earthy, warm, tactile. Display serif + Cyrillic grotesk body. No purple, no glass. Scheme A (Espresso, chosen) shown; primitives can be swapped for Scheme B (Forest) without touching semantic names.",

  "color": {
    "ink":   { "900": { "$type": "color", "$value": "#1A130D" }, "700": { "$type": "color", "$value": "#3C2E22" }, "500": { "$type": "color", "$value": "#6E5A48" } },
    "paper": { "0": { "$type": "color", "$value": "#FFFFFF" }, "50": { "$type": "color", "$value": "#F7F0E6" }, "100": { "$type": "color", "$value": "#EDE2D2" } },
    "espresso": { "800": { "$type": "color", "$value": "#5A3120" }, "700": { "$type": "color", "$value": "#6F3B26" }, "600": { "$type": "color", "$value": "#854A31" } },
    "ember": { "500": { "$type": "color", "$value": "#C5683B" } },
    "pine":  { "600": { "$type": "color", "$value": "#2C4A3B" } },
    "state": { "success": { "$type": "color", "$value": "#2E7D4F" }, "warning": { "$type": "color", "$value": "#A9781C" }, "danger": { "$type": "color", "$value": "#A8392B" } },

    "surface":        { "$type": "color", "$value": "{color.paper.50}" },
    "surface-raised": { "$type": "color", "$value": "{color.paper.0}" },
    "surface-inverse":{ "$type": "color", "$value": "{color.espresso.800}" },
    "text":           { "$type": "color", "$value": "{color.ink.900}" },
    "text-muted":     { "$type": "color", "$value": "{color.ink.500}" },
    "text-on-inverse":{ "$type": "color", "$value": "{color.paper.50}" },
    "action-primary":            { "$type": "color", "$value": "{color.espresso.700}" },
    "action-primary-foreground": { "$type": "color", "$value": "{color.paper.0}" },
    "action-primary-hover":      { "$type": "color", "$value": "{color.espresso.600}" },
    "accent":         { "$type": "color", "$value": "{color.ember.500}" },
    "border":         { "$type": "color", "$value": "{color.paper.100}" },
    "focus-ring":     { "$type": "color", "$value": "{color.pine.600}" }
  },

  "font": {
    "family": {
      "display": { "$type": "fontFamily", "$value": "var(--font-display), Georgia, serif" },
      "body":    { "$type": "fontFamily", "$value": "var(--font-body), system-ui, sans-serif" }
    },
    "size":   { "sm": { "$type": "dimension", "$value": "0.9375rem" }, "base": { "$type": "dimension", "$value": "1.0625rem" }, "lg": { "$type": "dimension", "$value": "1.375rem" }, "xl": { "$type": "dimension", "$value": "2rem" }, "2xl": { "$type": "dimension", "$value": "3rem" }, "display": { "$type": "dimension", "$value": "clamp(2.75rem, 7vw, 5.25rem)" } },
    "weight": { "regular": { "$type": "number", "$value": 400 }, "medium": { "$type": "number", "$value": 500 }, "bold": { "$type": "number", "$value": 700 } },
    "leading":{ "tight": { "$type": "number", "$value": 1.05 }, "normal": { "$type": "number", "$value": 1.6 } }
  },

  "space":  { "1": { "$type": "dimension", "$value": "0.25rem" }, "2": { "$type": "dimension", "$value": "0.5rem" }, "3": { "$type": "dimension", "$value": "0.75rem" }, "4": { "$type": "dimension", "$value": "1rem" }, "6": { "$type": "dimension", "$value": "1.5rem" }, "8": { "$type": "dimension", "$value": "2rem" }, "12": { "$type": "dimension", "$value": "3rem" }, "20": { "$type": "dimension", "$value": "5rem" }, "section": { "$type": "dimension", "$value": "{space.20}" } },

  "radius": { "sm": { "$type": "dimension", "$value": "0.25rem" }, "md": { "$type": "dimension", "$value": "0.5rem" }, "lg": { "$type": "dimension", "$value": "1.25rem" }, "interactive": { "$type": "dimension", "$value": "{radius.md}" } },

  "shadow": {
    "sm": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "1px", "blur": "2px", "spread": "0", "color": "rgba(26,19,13,0.08)" } },
    "md": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "10px", "blur": "30px", "spread": "-8px", "color": "rgba(26,19,13,0.18)" } }
  },

  "motion": { "fast": { "$type": "duration", "$value": "150ms" }, "base": { "$type": "duration", "$value": "300ms" }, "ease": { "$type": "cubicBezier", "$value": [0.22, 1, 0.36, 1] } }
}
