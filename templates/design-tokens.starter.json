{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "_comment": "Jazz design tokens — W3C DTCG. Three tiers: primitive -> semantic -> component. Replace primitive values per the chosen direction; keep semantic names stable so schemes swap by editing primitives only. NEVER hardcode values in components.",

  "color": {
    "_comment-primitive": "TIER 1 — primitives, named by appearance",
    "ink":   { "900": { "$type": "color", "$value": "#16110D" }, "700": { "$type": "color", "$value": "#3A322B" }, "500": { "$type": "color", "$value": "#6B5D52" } },
    "paper": { "0": { "$type": "color", "$value": "#FFFFFF" }, "50": { "$type": "color", "$value": "#FBF7F1" }, "100": { "$type": "color", "$value": "#F3ECE2" } },
    "brand": { "700": { "$type": "color", "$value": "#7A3B2E" }, "600": { "$type": "color", "$value": "#94483A" }, "400": { "$type": "color", "$value": "#C08374" } },
    "accent":{ "500": { "$type": "color", "$value": "#2E5A4F" } },
    "state": { "success": { "$type": "color", "$value": "#2E7D4F" }, "warning": { "$type": "color", "$value": "#B5811E" }, "danger": { "$type": "color", "$value": "#B23A2E" } },

    "_comment-semantic": "TIER 2 — semantic, what components use",
    "surface":      { "$type": "color", "$value": "{color.paper.50}" },
    "surface-raised": { "$type": "color", "$value": "{color.paper.0}" },
    "text":         { "$type": "color", "$value": "{color.ink.900}" },
    "text-muted":   { "$type": "color", "$value": "{color.ink.500}" },
    "action-primary":            { "$type": "color", "$value": "{color.brand.700}" },
    "action-primary-foreground": { "$type": "color", "$value": "{color.paper.0}" },
    "action-primary-hover":      { "$type": "color", "$value": "{color.brand.600}" },
    "border":       { "$type": "color", "$value": "{color.paper.100}" },
    "focus-ring":   { "$type": "color", "$value": "{color.accent.500}" }
  },

  "font": {
    "family": {
      "display": { "$type": "fontFamily", "$value": "\"Replace Display\", Georgia, serif" },
      "body":    { "$type": "fontFamily", "$value": "\"Replace Body\", system-ui, sans-serif" }
    },
    "size":   { "xs": { "$type": "dimension", "$value": "0.8125rem" }, "sm": { "$type": "dimension", "$value": "0.9375rem" }, "base": { "$type": "dimension", "$value": "1.0625rem" }, "lg": { "$type": "dimension", "$value": "1.375rem" }, "xl": { "$type": "dimension", "$value": "2rem" }, "2xl": { "$type": "dimension", "$value": "3rem" }, "display": { "$type": "dimension", "$value": "clamp(2.5rem, 6vw, 4.5rem)" } },
    "weight": { "regular": { "$type": "number", "$value": 400 }, "medium": { "$type": "number", "$value": 500 }, "bold": { "$type": "number", "$value": 700 } },
    "leading":{ "tight": { "$type": "number", "$value": 1.1 }, "normal": { "$type": "number", "$value": 1.6 } }
  },

  "space":  { "1": { "$type": "dimension", "$value": "0.25rem" }, "2": { "$type": "dimension", "$value": "0.5rem" }, "3": { "$type": "dimension", "$value": "0.75rem" }, "4": { "$type": "dimension", "$value": "1rem" }, "6": { "$type": "dimension", "$value": "1.5rem" }, "8": { "$type": "dimension", "$value": "2rem" }, "12": { "$type": "dimension", "$value": "3rem" }, "20": { "$type": "dimension", "$value": "5rem" }, "section": { "$type": "dimension", "$value": "{space.20}" } },

  "radius": { "sm": { "$type": "dimension", "$value": "0.25rem" }, "md": { "$type": "dimension", "$value": "0.5rem" }, "lg": { "$type": "dimension", "$value": "1rem" }, "interactive": { "$type": "dimension", "$value": "{radius.md}" } },

  "shadow": {
    "sm": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "1px", "blur": "2px", "spread": "0", "color": "rgba(22,17,13,0.08)" } },
    "md": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "6px", "blur": "20px", "spread": "-4px", "color": "rgba(22,17,13,0.12)" } }
  },

  "motion": { "fast": { "$type": "duration", "$value": "150ms" }, "base": { "$type": "duration", "$value": "250ms" }, "ease": { "$type": "cubicBezier", "$value": [0.22, 1, 0.36, 1] } },

  "component": {
    "_comment": "TIER 3 — component tokens, only when an element needs its own knob",
    "button-primary-bg":   { "$type": "color", "$value": "{color.action-primary}" },
    "button-primary-fg":   { "$type": "color", "$value": "{color.action-primary-foreground}" },
    "input-border":        { "$type": "color", "$value": "{color.border}" }
  }
}
